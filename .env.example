# API server
NODE_ENV=development
PORT=8080
HOST=0.0.0.0

# MongoDB
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=playable_ads_studio

# LLM provider selection: mock | openrouter
LLM_PROVIDER=mock

# OpenRouter (required only when LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_TIMEOUT_MS=20000
